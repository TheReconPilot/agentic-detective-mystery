# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Local env overrides (per-developer model selection, etc.)
.env

# Test/coverage artifacts
.coverage
.pytest_cache/
htmlcov/

# Tooling
.claude/
.mypy_cache/
.ruff_cache/

# Per-developer playthrough cases (default MYSTERY_CASES_DIR). Anchored to the
# repo root so it does NOT swallow evals/cases/, which holds the eval fixtures.
/cases/

# Chroma indexes are derived from bibles and should not be committed.
*.chroma/
